{
  "entities": {
    "EquipmentRecord": {
      "title": "Equipment Record",
      "description": "Metadata for extracted optical equipment data, excluding the heavy image.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["CTO", "MUFA", "RESERVA"] },
        "coordinates": { "type": "string" },
        "timestamp": { "type": "string" },
        "power": { "type": "string" },
        "extractedAt": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "code", "type", "coordinates", "projectId"]
    },
    "EquipmentImage": {
      "title": "Equipment Image",
      "description": "Separated heavy Base64 image data for lazy loading.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "imageUrl"]
    },
    "ProjectIndex": {
      "title": "Project Index",
      "description": "A summary document containing all records for a project in a single document to save read quota.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/EquipmentRecordSummary" }
        }
      }
    },
    "EquipmentRecordSummary": {
      "title": "Equipment Record Summary",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string" },
        "coordinates": { "type": "string" },
        "power": { "type": "string" },
        "extractedAt": { "type": "string" }
      }
    },
    "KmzProject": {
      "title": "KMZ Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "items": { "type": "array" },
        "tendidos": { "type": "array" }
      }
    },
    "TendidoReport": {
      "title": "Tendido Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "contractorId": { "type": "string" },
        "userId": { "type": "string" },
        "technicianId": { "type": "string" },
        "timestamp": { "type": "string" },
        "data": { "type": "object" }
      }
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Technician": {
      "title": "Technician",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contractorId": { "type": "string" },
        "name": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contractorId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "lastRecordsUpdate": { "type": "string", "format": "date-time" },
        "lastKmzUpdate": { "type": "string", "format": "date-time" },
        "lastReportsUpdate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/contractors/{id}": {
      "schema": "Contractor",
      "description": "Company/Division isolation entity."
    },
    "/technicians/{id}": {
      "schema": "Technician",
      "description": "Technician identity and access credentials."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project metadata and sync timestamps."
    },
    "/records/{id}": {
      "schema": "EquipmentRecord",
      "description": "Individual metadata for equipment."
    },
    "/record_images/{id}": {
      "schema": "EquipmentImage",
      "description": "Heavy image storage."
    },
    "/project_indexes/{projectId}": {
      "schema": "ProjectIndex",
      "description": "The 'Bucket' document for project-wide inventory list."
    },
    "/kmz_projects/{projectId}": {
      "schema": "KmzProject",
      "description": "The project technical structure and KMZ items."
    },
    "/tendido_reports/{id}": {
      "schema": "TendidoReport",
      "description": "Reports for fiber stretching."
    }
  }
}
