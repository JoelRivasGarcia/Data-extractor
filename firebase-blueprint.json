{
  "entities": {
    "EquipmentRecord": {
      "title": "Equipment Record",
      "description": "Data extracted from optical equipment photos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["CTO", "MUFA", "RESERVA"] },
        "coordinates": { "type": "string" },
        "timestamp": { "type": "string" },
        "power": { "type": "string" },
        "imageUrl": { "type": "string" },
        "extractedAt": { "type": "string" },
        "method": { "type": "string", "enum": ["LOCAL", "GEMINI", "HYBRID"] },
        "aiModel": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "code", "type", "coordinates", "timestamp", "power", "imageUrl", "extractedAt", "method", "userId", "projectId"]
    },
    "Project": {
      "title": "Project",
      "description": "A group of equipment records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] }
      },
      "required": ["id", "name", "createdAt", "createdBy", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Private user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects."
    },
    "/records/{recordId}": {
      "schema": "EquipmentRecord",
      "description": "Collection of equipment records."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    }
  }
}
